# Example environment configuration for Lysara Investments

# Coinbase
COINBASE_API_KEY=your_coinbase_key
COINBASE_SECRET_KEY=your_coinbase_secret
# Coinbase Developer Platform (AgentKit)
# Current AgentKit key names (recommended)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Optional network selector (e.g. base-sepolia, base-mainnet)
NETWORK_ID=base-sepolia
# Optional chain id fallback (used to infer NETWORK_ID if NETWORK_ID is unset)
CHAIN_ID=84532
# Optional explicit RPC endpoint for connectivity checks
RPC_URL=

# Backward compatibility aliases (optional)
CDP_API_KEY=
CDP_PROJECT_ID=

# Robinhood crypto trading
ROBINHOOD_API_KEY=
ROBINHOOD_PRIVATE_KEY=
ROBINHOOD_PUBLIC_KEY=
ROBINHOOD_CRYPTO_API_BASE_URL=https://trading.robinhood.com
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=

# Reddit, News, Sentiment
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=LysaraSentimentBot/1.0
ENABLE_REDDIT_SENTIMENT=false
REDDIT_SUBREDDITS=
REDDIT_SUBS=
NEWSAPI_KEY=
CRYPTOPANIC_KEY=
CRYPTOPANIC_API_BASE_URL=https://cryptopanic.com/api/developer/v2
X_API_KEY=
X_API_KEY_SECRET=
X_BEARER_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
WHALE_ALERT_API_KEY=
FINNHUB_API_KEY=
TRADINGECONOMICS_API_KEY=
TRADINGECONOMICS_API_SECRET=
COINMARKETCAL_API_KEY=
SLACK_WEBHOOK_URL=

# System Config
SIMULATION_MODE=True
ENABLE_CRYPTO_TRADING=true
ENABLE_STOCK_TRADING=true
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
# Do not include /v2 at the end
ALPACA_BASE_URL=https://paper-api.alpaca.markets
OPENAI_API_KEY=your_openai_key
OPENAI_DECISION_MODEL=gpt-4o-mini
AI_DECISION_MIN_INTERVAL_SECONDS=300
AI_DECISION_CACHE_TTL_SECONDS=1800
AI_OPENAI_RETRIES=2
ENABLE_AI_STRATEGY=true
ENABLE_AI_ASSET_DISCOVERY=false
ENABLE_AI_TRADE_EXECUTION=false
FOREX_ENABLED=false
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
TRADE_SYMBOLS=BTC-USD,ETH-USD,SOL-USD,ADA-USD
SHOW_MANUAL_TRADING_UI=False

# Tier 2 Control API (Sylana Vessel integration)
# Required secret key for the X-API-Key header used by Sylana Vessel.
CONTROL_API_SECRET=replace_with_long_random_secret
# Port the control API listens on (default 18791).
CONTROL_API_PORT=18791
# Bind address for the control API. Use 0.0.0.0 inside containers.
CONTROL_API_HOST=127.0.0.1
# Guardrail controls for autonomous operations policy.
LIVE_TRADING_ENABLED=false
ALLOW_LIVE_TRADING_STARTUP=false
OPS_MIN_CONFIDENCE=0.60
OPS_MAX_NOTIONAL_PER_TRADE=5000
OPS_MAX_PRICE_AGE_SECONDS=180
OPS_DEDUPE_SECONDS=60
OVERRIDE_DEFAULT_TTL_MINUTES=15
OVERRIDE_ALLOWED_CONTROLS=trade_cooldown,confidence_minimum,approval_requirement,event_risk_warning,sentiment_threshold
OPS_MAX_SINGLE_POSITION_PCT=20
OPS_MAX_TOTAL_GROSS_EXPOSURE_PCT=100
POSITION_SIZING_MAX_KELLY_FRACTION=0.25
POSITION_SIZING_MIN_HISTORY_TRADES=8
EVENT_RISK_FILE=dashboard/data/event_risk_cache.json
EVENT_RISK_LOOKAHEAD_HOURS=24
EVENT_RISK_WARNING_THRESHOLD=0.45
EVENT_RISK_BLOCK_THRESHOLD=0.70
EVENT_RISK_REDUCTION_THRESHOLD=0.85
EVENT_RISK_REDUCTION_FACTOR=0.50
SENTIMENT_LOOP_INTERVAL_SECONDS=300
EVENT_RISK_LOOP_INTERVAL_SECONDS=300
