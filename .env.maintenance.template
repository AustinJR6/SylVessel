# =============================================================================
# Sylana Maintenance Controller Environment Template
# Copy this onto the separate maintenance host and fill in the secrets.
# The controller should run outside the main Vessel droplet.
# =============================================================================

# Supabase database connection used for repair incidents/runs/events.
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# GitHub token with repo + actions access for the backend and app repositories.
GITHUB_TOKEN=ghp_...

# Vessel backend the controller monitors.
VESSEL_API_BASE_URL=https://167-99-127-14.sslip.io

# Shared token used to read bounded log tails from /repairs/logs/tail.
MAINTENANCE_READ_TOKEN=

# Repository configuration.
MAINTENANCE_BACKEND_REPO=AustinJR6/SylVessel
MAINTENANCE_APP_REPO=AustinJR6/SoulsApp

# Where disposable repair workspaces are created.
MAINTENANCE_CLONE_ROOT=./data/maintenance_workspaces

# Poll cadence in seconds.
MAINTENANCE_POLL_SECONDS=300

# Start in diagnosis-first mode. Use proposal only when you want the controller
# to open repair PRs automatically for eligible incidents.
MAINTENANCE_REPAIR_MODE=diagnosis

# Claude Code / Codex execution settings.
MAINTENANCE_CODEX_BIN=codex
MAINTENANCE_CODEX_MODEL=gpt-5.4
