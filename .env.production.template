# =============================================================================
# Sylana Vessel — Production Environment Variables
# Copy this to .env on the droplet and fill in your values.
# Location: /opt/sylvessel/.env
#
# NEVER commit the actual .env file — it contains secrets.
# =============================================================================

# ── AI Providers ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# ── Database (Supabase — unchanged from Cloud Run) ────────
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# ── Memory encryption ─────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MEMORY_ENCRYPTION_KEY=

# ── Search ────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=

# ── Image generation (Modelslab) ──────────────────────────
MODELSLAB_API_KEY=

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=

# ── Push notifications (Svix) ─────────────────────────────
SVIX_WEBHOOK_SECRET=

# ── OpenClaw gateway (internal — do not change) ──────────
# FastAPI reaches OpenClaw on the host via host-gateway
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
LYSARA_OPS_BASE_URL=http://host.docker.internal:18791
LYSARA_OPS_API_KEY=
LYSARA_OPS_TIMEOUT_SECONDS=15
LYSARA_AUTONOMOUS_ENABLED=false
LYSARA_OPERATOR_INTERVAL_SECONDS=300

# ── Code execution sandbox limits ────────────────────────
CODE_EXEC_CPUS=1
CODE_EXEC_MEMORY=512m
MAX_CODE_TIMEOUT_SECONDS=30

# ── Server ────────────────────────────────────────────────
PORT=8080
ENV=production

# ── Google Cloud Storage (optional — leave blank to skip) ─
# GCS is no longer required on DO. Leave blank unless you want
# produced files from code execution to be uploaded to GCS.
# GOOGLE_CLOUD_STORAGE_BUCKET=
# GOOGLE_APPLICATION_CREDENTIALS=
